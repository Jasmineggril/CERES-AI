# Example environment variables for local development.
# Copy this file to .env or add the values to your Replit env.

# Database connection for local Postgres or Supabase.
# For Supabase, use the PostgreSQL connection string from the Supabase dashboard.
# The Supabase publishable key (sb_publishable_...) is NOT the database password.
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# Alternative local Postgres variables.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=postgres

# Session secret for express-session.
SESSION_SECRET="ceres-ai-dev-secret"

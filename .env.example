# Example environment variables for local development.
# Copy this file to .env or add the values to your Replit env.

# Database connection for local Postgres or Supabase.
# For Supabase, use the PostgreSQL connection string from the Supabase dashboard.
# The Supabase publishable key (sb_publishable_...) is NOT the database password.
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# Alternative local Postgres variables.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=postgres

# Session secret for express-session.
SESSION_SECRET="ceres-ai-dev-secret"

# Frontend Supabase variables (used by Vite client).
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="public-anon-key"

# Optional Supabase admin variables (do not commit secrets to git).
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
# SUPABASE_SECRET_KEY="sb_secret_xxx"
# SUPABASE_JWKS_URL="https://your-project.supabase.co/auth/v1/.well-known/jwks.json"
